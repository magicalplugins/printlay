# Copy to .env for local dev. In production, use `fly secrets set KEY=value`.

# Supabase (Auth + Postgres)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Only set SUPABASE_JWT_SECRET on legacy HS256 projects. New Supabase
# projects sign with asymmetric keys and the backend pulls the JWKS from
# <SUPABASE_URL>/auth/v1/.well-known/jwks.json automatically.
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Object storage (S3-compatible)
# In production these are auto-injected by `fly storage create` (Tigris).
# For local dev, point at any S3-compatible store: Tigris, R2, AWS S3, MinIO, etc.
STORAGE_ENDPOINT=https://fly.storage.tigris.dev
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=printlay-files
STORAGE_REGION=auto
STORAGE_PUBLIC_BASE_URL=

# Frontend (Vite reads VITE_-prefixed vars at build time)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Misc
ENVIRONMENT=development

# Optional: extra CORS origins (comma-separated), and rate-limit
CORS_EXTRA_ORIGINS=
RATE_LIMIT_GENERATE_PER_HOUR=60

# Billing (Stripe)
# Use test keys locally (sk_test_..., whsec_...).
# Run `stripe listen --forward-to localhost:8000/api/billing/webhook` to forward webhooks in dev.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from your Stripe dashboard (create products Starter / Pro / Studio, each with monthly + annual prices)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_ANNUAL=

# Admin access (comma-separated email addresses — case insensitive)
# These accounts see the Admin link in the nav and can access /app/admin.
ADMIN_EMAILS=

# Bulk email via Resend (https://resend.com — free tier 3k/month)
# Without this, the admin "Compose message" email channel is disabled.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Printlay <hello@printlay.io>

# Bulk SMS via Twilio (optional — SMS channel is silently disabled if any of these are missing)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
